{"credit":"Created by FreshLX for Fresh Animations","id":"player_firstperson","animations":[{"var.fp_rarmrx":"torad(40*if(var.requip==1,0,var.requip)+((10+20*limb_speed*cos(var.t_jump*pi))*exp(-var.t_jump*pi)*var.jump-(10+10*sin(var.lsj))*var.fall+(-12*cos(pi/5+var.Btsw+sin(pi/5+var.Btsw)/(1.7+limb_speed))*clamp(1+limb_speed*3,0,1))*var.tread)*max(0,1-var.requip))*0","var.fp_larmrx":"torad(40*if(var.lequip==1,0,var.lequip)+((10+20*limb_speed*cos(var.t_jump*pi))*exp(-var.t_jump*pi)*var.jump-(10-10*sin(var.lsj))*var.fall+(-12*cos(pi/5+var.Btsw+sin(pi/5+var.Btsw)/(1.7+limb_speed))*clamp(1+limb_speed*3,0,1))*var.tread)*max(0,1-var.lequip))*0","var.fp_rarmry":"torad(5+60*if(var.requip==1,0,var.requip)+(-1.5*cos(var.Bt/2)-20*var.sneak-40*(var.prone-var.climb)+10*limb_speed+(30-10*cos(var.lsj))*var.fall+(9*sin(-pi/5+var.Btsw-sin(-pi/2.5+var.Btsw)/1.5)-9)*var.tread)*max(0,1-var.requip))","var.fp_larmry":"torad(-5-60*if(var.lequip==1,0,var.lequip)+(-1.5*cos(var.Bt/2)+20*var.sneak+40*(var.prone-var.climb)-10*limb_speed-(30-10*cos(var.lsj))*var.fall+(-9*sin(-pi/5+var.Btsw-sin(-pi/2.5+var.Btsw)/1.5)+9)*var.tread)*max(0,1-var.lequip))","var.fp_rarmrz":"torad(6+20*if(var.requip==1,0,var.requip)+(0.5*sin(var.Bt)+10*var.sneak-20*var.prone-10*limb_speed-40*exp(-var.t_jump*pi)*var.jump+30*var.fall-(12*sin(-pi/8+var.t_land*pi)*(1+limb_speed))*var.land+(-5*sin(pi/8+var.Btsw+cos(pi/8+var.Btsw)/5)-9)*var.tread*3)*max(0,1-var.requip))","var.fp_larmrz":"torad(-6-20*if(var.lequip==1,0,var.lequip)+(-0.5*sin(var.Bt)-10*var.sneak+20*var.prone+10*limb_speed+40*exp(-var.t_jump*pi)*var.jump-30*var.fall+(12*sin(-pi/8+var.t_land*pi)*(1+limb_speed))*var.land+(5*sin(pi/8+var.Btsw+cos(pi/8+var.Btsw)/5)+9)*var.tread*3)*max(0,1-var.lequip))","var.fp_rarmtx":"-5+cos(var.Bt/2)/9*(1-var.requip)","var.fp_larmtx":"5+cos(var.Bt/2)/9*(1-var.lequip)","var.fp_rarmty":"2+(sin(var.Bt)/9-limb_speed-3*exp(-var.t_jump*pi)*var.jump+3*var.fall-0.5*cos(var.t_land*pi)*min(sqrt((1-var.t_land)*2),1)*var.land)*(1-var.requip)","var.fp_larmty":"2+(sin(var.Bt)/9-limb_speed-3*exp(-var.t_jump*pi)*var.jump+3*var.fall-0.5*cos(var.t_land*pi)*min(sqrt((1-var.t_land)*2),1)*var.land)*(1-var.lequip)","var.fp_rarmtz":"0","var.fp_larmtz":"0"}]}