{"credit":"Created by FreshLX for Fresh Animations","id":"player_equipment","animations":[{"var.eqp_bodyrx":"(sin(sqrt(swing_progress)*pi)*0.1)*(var.rswingingA+var.lswingingA)","var.eqp_bodyry":"(var.attC*0.3/2+(-0.4)*var.idle)*(var.rswingingA-var.lswingingA)","var.eqp_bodyrz":"0","var.eqp_bodytx":"(sin(sqrt(swing_progress)*pi)*0.5+(0.2)*var.idle)*(var.rswingingA-var.lswingingA)","var.eqp_bodyty":"0","var.eqp_bodytz":"0"},{"var.eqp_rarmrx":"(-pi/10*(1+var.sneak)*(1-pow(var.gfast,2)))*(1-cos(var.requip*pi))/2+torad((-90*cos(swing_progress*pi)*var.attA+(head_pitch-0.7))*var.rswingingA+(-18*var.attC+10*var.idle)*var.lswingingA)","var.eqp_larmrx":"(-pi/10*(1+var.sneak)*(1-pow(var.gfast,2)))*(1-cos(var.lequip*pi))/2+torad((-90*cos(swing_progress*pi)*var.attA+(head_pitch-0.7))*var.lswingingA+(-18*var.attC+10*var.idle)*var.rswingingA)","var.eqp_rarmry":"torad(((-15+25*cos(swing_progress*pi))*var.attA-10*var.idle+var.hy/1.5*if(is_riding,0.5,1))*var.rswinging-(-10*var.attC-10*var.idle)*var.lswinging)","var.eqp_larmry":"torad(-((-15+25*cos(swing_progress*pi))*var.attA-10*var.idle+var.hy/1.5*if(is_riding,0.5,1))*var.lswinging+(-10*var.attC-10*var.idle)*var.rswinging)","var.eqp_rarmrz":"torad((-20*sin((1-swing_progress)*pi)*var.attA+5)*var.rswinging-(-5)*var.lswinging)","var.eqp_larmrz":"torad(-(-20*sin((1-swing_progress)*pi)*var.attA+5)*var.lswinging+(-5)*var.rswinging)","var.eqp_rarmtx":"0","var.eqp_larmtx":"0","var.eqp_rarmty":"0","var.eqp_larmty":"0","var.eqp_rarmtz":"(-0.4)*var.requip","var.eqp_larmtz":"(-0.4)*var.lequip"},{"var.eqp_rfootrx":"torad((-var.attC*3*0+4*var.idle)*var.rswingingA+(sin(sqrt(swing_progress)*pi))*var.lswingingA)","var.eqp_lfootrx":"torad((-var.attC*3*0+4*var.idle)*var.lswingingA+(sin(sqrt(swing_progress)*pi))*var.rswingingA)","var.eqp_rfootry":"torad(-(-25*var.idle)*var.lswingingA*0)","var.eqp_lfootry":"torad((-25*var.idle)*var.rswingingA*0)","var.eqp_rfootrz":"0","var.eqp_lfootrz":"0"}]}